  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4A5C50"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#C8CAC8"
      }
    },
    {
      "name": "Color",
      "scope": [
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#B8906A"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C4403A"
      }
    },
    {
      "name": "Storage - Type",
      "scope": [
        "storage.type"
      ],
      "settings": {
        "foreground": "#6B9EAF"
      }
    },
    {
      "name": "Storage - Modifier",
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#6B9EAF"
      }
    },
    {
      "name": "Control Keyword",
      "scope": [
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#6B9EAF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator, Misc",
      "scope": [
        "keyword.control",
        "constant.other.color",
        "meta.tag",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#6B9EAF"
      }
    },
    {
      "name": "Operator, Misc",
      "scope": [
        "keyword.control.trycatch"
      ],
      "settings": {
        "foreground": "#C4403A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Identifier",
      "scope": [
        "keyword.other.unit",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#A8845A"
      }
    },
    {
      "name": "Punctuation, Brace",
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "meta.brace",
        "keyword.operator.type.annotation"
      ],
      "settings": {
        "foreground": "#6E7278"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#A8845A"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#7AAE8E"
      }
    },
    {
      "name": "Special Method",
      "scope": [
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#83697A"
      }
    },
    {
      "name": "Macro",
      "scope": [
        "entity.name.function.macro"
      ],
      "settings": {
        "foreground": "#83697A"
      }
    },
    {
      "name": "Block Level Variable",
      "scope": [
        "meta.block variable.other"
      ],
      "settings": {
        "foreground": "#C8CAC8"
      }
    },
    {
      "name": "Enum Member",
      "scope": [
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#B8906A"
      }
    },
    {
      "name": "Constant, Language, Support",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character",
        "constant.escape"
      ],
      "settings": {
        "foreground": "#B8906A"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#B8906A"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#7A8C9E"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string",
        "constant.other.symbol",
        "markup.heading",
        "markup.inline.raw.string"
      ],
      "settings": {
        "foreground": "#8A9E72"
      }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#8EAAB8"
      }
    },
    {
      "name": "Namespace, Module",
      "scope": [
        "entity.name.type.module",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#A8845A"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#A8845A"
      }
    },
    {
      "name": "Import",
      "scope": [
        "keyword.control.import",
        "keyword.import",
        "meta.import"
      ],
      "settings": {
        "foreground": "#B8906A"
      }
    },
    {
      "name": "CSS Class and Support",
      "scope": [
        "source.css support.type.property-name",
        "source.scss support.type.property-name"
      ],
      "settings": {
        "foreground": "#8EAAB8"
      }
    },
    {
      "name": "Language Method",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#C4403A"
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6B9EAF"
      }
    },
    {
      "name": "CSS Class",
      "scope": [
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#A8845A"
      }
    },
    {
      "name": "Inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#4A7A5A"
      }
    },
    {
      "name": "Deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#C4403A"
      }
    },
    {
      "name": "Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#C47840"
      }
    },
    {
      "name": "Regular Expression",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#A87050"
      }
    },
    {
      "name": "Escape Character",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#8EAAB8"
      }
    },
    {
      "name": "URL",
      "scope": [
        "*url*",
        "*link*",
        "*uri*"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "tag.decorator.js entity.name.tag.js"
      ],
      "settings": {
        "foreground": "#6B9EAF"
      }
    },
    {
      "name": "JSON Key - Level 0",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#7A8C9E"
      }
    },
    {
      "name": "JSON Key - Level 1",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#A8845A"
      }
    },
    {
      "name": "JSON Key - Level 2",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#B8906A"
      }
    },
    {
      "name": "Markdown - Heading",
      "scope": [
        "markdown.heading",
        "entity.name.section.markdown",
        "markup.heading.markdown"
      ],
      "settings": {
        "foreground": "#8EAAB8"
      }
    },
    {
      "name": "Markup - Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#C4403A"
      }
    },
    {
      "name": "Markup - Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown - Link",
      "scope": [
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#B8906A"
      }
    },
    {
      "name": "HTML text",
      "scope": [
        "text.html",
        "text.log"
      ],
      "settings": {
        "foreground": "#C8CAC8"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#A2A8A4",
    "variable": "#C8CAC8",
    "arithmetic": "#A87050",
    "method": "#8EAAB8",
    "function": "#7AAE8E",
    "operator": "#A8845A",
    "parameter.declaration": "#A2A8A4",
    "parameter.definition": "#A2A8A4",
    "variable.readonly": "#C8CAC8",
    "variable.readonly.local": "#C8CAC8",
    "variable.readonly.defaultLibrary": "#C8CAC8",
    "macro": "#83697A",
    "keyword.controlFlow": {
      "foreground": "#6B9EAF",
      "fontStyle": "bold"
    }
  }
}
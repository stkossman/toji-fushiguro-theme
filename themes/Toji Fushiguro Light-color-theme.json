  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6B8274"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#2E3133"
      }
    },
    {
      "name": "Color",
      "scope": [
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#9E744A"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#B5312B"
      }
    },
    {
      "name": "Storage - Type",
      "scope": [
        "storage.type"
      ],
      "settings": {
        "foreground": "#457B8F"
      }
    },
    {
      "name": "Storage - Modifier",
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#457B8F"
      }
    },
    {
      "name": "Control Keyword",
      "scope": [
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#457B8F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator, Misc",
      "scope": [
        "keyword.control",
        "constant.other.color",
        "meta.tag",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#457B8F"
      }
    },
    {
      "name": "Operator, Misc",
      "scope": [
        "keyword.control.trycatch"
      ],
      "settings": {
        "foreground": "#B5312B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Identifier",
      "scope": [
        "keyword.other.unit",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#8C6538"
      }
    },
    {
      "name": "Punctuation, Brace",
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "meta.brace",
        "keyword.operator.type.annotation"
      ],
      "settings": {
        "foreground": "#A2A8A4"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#8C6538"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#4A8567"
      }
    },
    {
      "name": "Special Method",
      "scope": [
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#6B4D60"
      }
    },
    {
      "name": "Macro",
      "scope": [
        "entity.name.function.macro"
      ],
      "settings": {
        "foreground": "#6B4D60"
      }
    },
    {
      "name": "Block Level Variable",
      "scope": [
        "meta.block variable.other"
      ],
      "settings": {
        "foreground": "#2E3133"
      }
    },
    {
      "name": "Enum Member",
      "scope": [
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#9E744A"
      }
    },
    {
      "name": "Constant, Language, Support",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character",
        "constant.escape"
      ],
      "settings": {
        "foreground": "#9E744A"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#9E744A"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#506478"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string",
        "constant.other.symbol",
        "markup.heading",
        "markup.inline.raw.string"
      ],
      "settings": {
        "foreground": "#63784A"
      }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#5C7C8C"
      }
    },
    {
      "name": "Namespace, Module",
      "scope": [
        "entity.name.type.module",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#8C6538"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#8C6538"
      }
    },
    {
      "name": "Import",
      "scope": [
        "keyword.control.import",
        "keyword.import",
        "meta.import"
      ],
      "settings": {
        "foreground": "#9E744A"
      }
    },
    {
      "name": "CSS Class and Support",
      "scope": [
        "source.css support.type.property-name",
        "source.scss support.type.property-name"
      ],
      "settings": {
        "foreground": "#5C7C8C"
      }
    },
    {
      "name": "Language Method",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#B5312B"
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#457B8F"
      }
    },
    {
      "name": "CSS Class",
      "scope": [
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#8C6538"
      }
    },
    {
      "name": "Inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#346143"
      }
    },
    {
      "name": "Deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#B5312B"
      }
    },
    {
      "name": "Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#A85C20"
      }
    },
    {
      "name": "Regular Expression",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#A65D24"
      }
    },
    {
      "name": "Escape Character",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#5C7C8C"
      }
    },
    {
      "name": "URL",
      "scope": [
        "*url*",
        "*link*",
        "*uri*"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "tag.decorator.js entity.name.tag.js"
      ],
      "settings": {
        "foreground": "#457B8F"
      }
    },
    {
      "name": "JSON Key - Level 0",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#506478"
      }
    },
    {
      "name": "JSON Key - Level 1",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#8C6538"
      }
    },
    {
      "name": "JSON Key - Level 2",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#9E744A"
      }
    },
    {
      "name": "Markdown - Heading",
      "scope": [
        "markdown.heading",
        "entity.name.section.markdown",
        "markup.heading.markdown"
      ],
      "settings": {
        "foreground": "#5C7C8C"
      }
    },
    {
      "name": "Markup - Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#B5312B"
      }
    },
    {
      "name": "Markup - Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown - Link",
      "scope": [
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#9E744A"
      }
    },
    {
      "name": "HTML text",
      "scope": [
        "text.html",
        "text.log"
      ],
      "settings": {
        "foreground": "#2E3133"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#5C6166",
    "variable": "#2E3133",
    "arithmetic": "#A65D24",
    "method": "#5C7C8C",
    "function": "#4A8567",
    "operator": "#8C6538",
    "parameter.declaration": "#5C6166",
    "parameter.definition": "#5C6166",
    "variable.readonly": "#2E3133",
    "variable.readonly.local": "#2E3133",
    "variable.readonly.defaultLibrary": "#2E3133",
    "macro": "#6B4D60",
    "keyword.controlFlow": {
      "foreground": "#457B8F",
      "fontStyle": "bold"
    }
  }
}